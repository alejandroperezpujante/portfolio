---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />

	<title>{t("head.title")}</title>

	<meta name="description" content={t("head.description")} />
	<meta name="author" content="Alejandro Pérez Pujante" />
	<meta name="keywords" content={t("head.keywords")} />
	<meta name="robots" content="index, follow" />
	<meta name="mobile-web-app-capable" content="yes" />
	<meta name="apple-mobile-web-app-capable" content="yes" />
	<meta name="canonical" content={canonicalUrl} />
	<meta name="generator" content={Astro.generator} />

	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

	<script is:inline>
		(() => {
			const storedTheme = localStorage.getItem("user-theme")?.trim().toLowerCase();
			if (storedTheme && ["dark", "light"].includes(storedTheme)) {
				document.documentElement.dataset.theme = storedTheme;
			}
		})();
	</script>
</head>
